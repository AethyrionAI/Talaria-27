# Talaria relay .env — Mac Mini M4 deployment (T6 Phase 1, OPEN_ITEMS #107)
#
# Copy to relay/.env on the Mini and fill the <PLACEHOLDERS>. Runbook:
# relay/docs/DEPLOY_MAC.md. Reference topology: OJAMD relay :8000 (production
# for the physical phone — the Mac relay serves dev pairings until T6 endgame).
#
# SECURITY: `production` makes the relay REFUSE to start with
# INTERNAL_API_KEY=replace-me (main.py guard). Keep it set so the guard
# actually enforces. Mint keys with:  openssl rand -hex 32
RELAY_ENVIRONMENT=production

# What pairing QR codes / setup payloads advertise to the PHONE. Tailnet IP of
# the Mini — NOT 127.0.0.1 (the phone would dial itself). Revisit
# `tailscale serve` HTTPS later (also dodges the #24e iCloud Private Relay trap).
PUBLIC_BASE_URL=http://100.79.222.100:8000/v1

# ABSOLUTE sqlite path (4 slashes = absolute). config.py anchors relative paths
# to the relay package (GH #59), but absolute removes all ambiguity about which
# DB the LaunchAgent opens. Moving this path later orphans pairings (GH #59).
DATABASE_URL=sqlite:////Users/owenjones/Documents/Claude/Talaria-27/relay/hermes_mobile.db

# Mint fresh — do NOT copy OJAMD's values. `replace-me` fails startup in production.
INTERNAL_API_KEY=<openssl rand -hex 32>
# Bootstrap protection for `hermes-mobile setup` — connector setup must present
# this. Mint fresh; export the same value in the shell running setup.
CONNECTOR_SETUP_SECRET=<openssl rand -hex 32>

ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
PAIRING_CODE_TTL_SECONDS=900
PHONE_PAIRING_CODE_TTL_SECONDS=600
PHONE_PAIRING_MAX_ATTEMPTS_PER_CODE=5
PHONE_PAIRING_MAX_ATTEMPTS_PER_IP=5
PHONE_PAIRING_RATE_LIMIT_WINDOW_SECONDS=300
HOST_ENROLLMENT_CODE_TTL_SECONDS=900
DEFAULT_USER_DISPLAY_NAME=Hermes User

# Real host bridge (the hermes-mobile connector on this same machine).
HERMES_ADAPTER=connector
# Absolute path to the Mac's Hermes CLI (validate with `hermes --version`;
# `command -v hermes` to find it — often ~/.hermes/hermes-agent/venv/bin/hermes
# or a symlink on PATH).
HERMES_COMMAND=<absolute path to hermes>
# Mac analog of O:\Hermes\ — where agent runs execute / files land (§2.1 of
# design/T6_MAC_BACKEND_SPEC.md). Create it first: mkdir -p ~/Hermes/agent-work
HERMES_WORKDIR=/Users/owenjones/Hermes/agent-work
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TOOLSETS=
HERMES_SOURCE=tool
HERMES_HISTORY_LIMIT=20
CONNECTOR_SYNC_WAIT_SECONDS=25
CONNECTOR_JOB_LEASE_SECONDS=180
CONNECTOR_HEARTBEAT_TIMEOUT_SECONDS=30
CONNECTOR_IDLE_POLL_INTERVAL_SECONDS=1.0

# APNs — run-completion pushes (#38). ABSOLUTE key path: the relay does NOT
# expand `~`. Key copied from OJAMD's C:\Secrets\apns\ → chmod 600.
# Bundle = org.aethyrion.talaria27 (this fork's PRODUCT_BUNDLE_IDENTIFIER —
# OJAMD's org.aethyrion.talaria is the WRONG topic for dev builds; pushes
# silently no-op on a topic mismatch). Each push registration carries its own
# bundle/environment, so these are fallbacks — set them correctly anyway.
APNS_KEY_PATH=/Users/owenjones/.secrets/apns/AuthKey_ALB34NY384.p8
APNS_KEY_CONTENTS=
APNS_KEY_ID=ALB34NY384
APNS_TEAM_ID=DNL25ZFSD2
APNS_BUNDLE_ID=org.aethyrion.talaria27
# dev-signed device builds = sandbox APNs; TestFlight/Release needs production.
APNS_ENVIRONMENT=development
APP_PRESENCE_STALE_SECONDS=120

# Push-watch (#38): relay polls the LOCAL gateway for run completion.
# GATEWAY_API_KEY = the MAC's API_SERVER_KEY from ~/.hermes/.env on the Mini —
# do NOT copy OJAMD's key.
GATEWAY_BASE_URL=http://127.0.0.1:8642
GATEWAY_API_KEY=<the Mac's API_SERVER_KEY>

# #21 Tier 2: whitelisted download dir for /v1/device/files. Subdir of the
# agent workdir, mirroring OJAMD (O:\Hermes + O:\Hermes\MobileDL).
# Create it first: mkdir -p ~/Hermes/agent-work/MobileDL
AGENT_FILES_DIR=/Users/owenjones/Hermes/agent-work/MobileDL

# Scheduled runs (#98) — leave enabled; SCHEDULER_ENABLED=false is the ops
# kill switch (schedule rows persist while off).
SCHEDULER_ENABLED=true
